{
	"name": "matricmaster",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "next dev",
		"build": "NEXT_PUBLIC_BUILD_VERSION=$npm_package_version NEXT_PUBLIC_COMMIT_HASH=$(git rev-parse --short HEAD) NEXT_PUBLIC_BUILD_TIMESTAMP=$(date -u +%Y-%m-%dT%H:%M:%SZ) next build",
		"start": "next start",
		"analyze": "ANALYZE=true next build",
		"lint": "biome check --write .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"typecheck": "tsc --noEmit",
		"test": "playwright test",
		"test:ui": "playwright test --ui",
		"test:debug": "playwright test --debug",
		"test:headed": "playwright test --headed",
		"test:report": "playwright show-report",
		"test:install": "playwright install",
		"test:unit": "vitest run",
		"test:unit:watch": "vitest",
		"db:generate": "drizzle-kit generate",
		"db:push": "drizzle-kit push",
		"db:migrate": "tsx src/lib/db/migrate.ts",
		"db:studio": "drizzle-kit studio",
		"db:seed": "tsx src/lib/db/seed/index.ts",
		"seed": "tsx scripts/seed.ts",
		"seed:faq": "tsx scripts/seed-faq-cache.ts",
		"db:reset": "drizzle-kit drop && drizzle-kit push && bun run db:seed"
	},
