{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/error-hint/layout,_N_T_/error-hint/page,_N_T_/error-hint"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/error-hint/__PAGE__",
    "/error-hint",
    "/_index",
    "/_head"
  ]
}