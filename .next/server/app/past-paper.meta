{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/past-paper/layout,_N_T_/past-paper/page,_N_T_/past-paper"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/past-paper/__PAGE__",
    "/past-paper",
    "/_index",
    "/_head"
  ]
}