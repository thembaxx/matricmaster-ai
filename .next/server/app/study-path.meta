{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/study-path/layout,_N_T_/study-path/page,_N_T_/study-path"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/study-path/__PAGE__",
    "/study-path",
    "/_index",
    "/_head"
  ]
}