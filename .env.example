# Better Auth
BETTER_AUTH_SECRET=your_secret_here
BETTER_AUTH_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/matricmaster

# SQLite (Fallback - used when PostgreSQL is unavailable)
SQLITE_DB_PATH=./data/sqlite.db

# AI
NEXT_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# AI Providers (Zhipu for OCR, others as fallback)
GROQ_API_KEY=your_groq_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
COHERE_API_KEY=your_cohere_api_key_here
MISTRAL_API_KEY=your_mistral_api_key_here

# File Upload (UploadThing)
UPLOADTHING_TOKEN=your_uploadthing_token_here

# Social Providers
# Google OAuth - Get from https://console.cloud.google.com/
# Add redirect URI in Google Cloud Console: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Twitter/X OAuth 2.0 - Get from https://developer.twitter.com/en/portal/dashboard
# Enable OAuth 2.0 in your app settings and add redirect URI: http://localhost:3000/api/auth/callback/twitter
TWITTER_CLIENT_ID=your_twitter_client_id
TWITTER_CLIENT_SECRET=your_twitter_client_secret

FACEBOOK_CLIENT_ID=your_facebook_client_id
FACEBOOK_CLIENT_SECRET=your_facebook_client_secret

# Email (Resend)
RESEND_API_KEY=your_resend_api_key
FROM_EMAIL=Lumni AI <noreply@matricmaster.ai>

# Analytics (PostHog)
POSTHOG_API_KEY=your_posthog_api_key
POSTHOG_PROJECT_ID=your_posthog_project_id
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_public_key

# Payments (Paystack)
PAYSTACK_PUBLIC_KEY=your_paystack_public_key
PAYSTACK_SECRET_KEY=your_paystack_secret_key

# Video Calls (Daily.co)
DAILY_API_KEY=your_daily_api_key
DAILY_DOMAIN=your_domain.daily.co

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# E2E Testing
BASE_URL=http://localhost:3000

# Vercel KV (Smart Caching for FAQs)
KV_URL=your_vercel_kv_rest_api_url
KV_REST_API_TOKEN=your_vercel_kv_token
KV_PREFIX=matricmaster:

# WhatsApp Business API
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_access_token
WHATSAPP_VERIFY_TOKEN=your_verify_token
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id

# Twilio Fallback (optional - if using Twilio instead of Meta API)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=+1234567890

# Sentry Error Monitoring
NEXT_PUBLIC_SENTRY_DSN=https://your_sentry_dsn_here

# Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
NEXT_PUBLIC_PREFER_GOOGLE_MAPS=false

# Ably (Real-time for Leaderboard)
ABLY_API_KEY=your_ably_api_key_here
NEXT_PUBLIC_ABLY_KEY=your_ably_key_here

# ============================================
# Enrichment & Mock Data (Demo Mode)
# ============================================

# Enable mock data generation and enrichment pipeline
ENABLE_MOCK_DATA=true

# Enable enrichment pipeline (web scraping, data normalization)
ENABLE_ENRICHMENT_PIPELINE=false

# Enable enriched UI components (heatmaps, streaks, progress rings)
ENABLE_ENRICHED_UI=true

# Default seed for reproducible mock data generation
MOCK_DATA_SEED=42

# Default mock data intensity: low | medium | high
MOCK_DATA_INTENSITY=high

# Months of simulated activity for mock data
MOCK_DATA_MONTHS=6
