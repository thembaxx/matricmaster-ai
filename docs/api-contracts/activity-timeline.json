{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "Activity Timeline API",
	"description": "GET /api/activity/:userId/timeline - Returns a user's activity timeline data including daily activity counts for the heatmap, recent activity stream entries, streak information, subject progress, accuracy trends, weak topics, and cohort comparison data.",
	"request": {
		"method": "GET",
		"url": "/api/activity/{userId}/timeline",
		"pathParams": {
			"$schema": "http://json-schema.org/draft-07/schema#",
			"type": "object",
			"required": ["userId"],
			"properties": {
				"userId": {
					"type": "string",
					"description": "The user ID to fetch activity timeline for."
				}
			}
		},
		"queryParams": {
			"$schema": "http://json-schema.org/draft-07/schema#",
			"type": "object",
			"properties": {
				"months": {
					"type": "integer",
					"description": "Number of months of activity history to return. Defaults to 6.",
					"default": 6,
					"minimum": 1,
					"maximum": 24
				},
				"limit": {
					"type": "integer",
					"description": "Maximum number of recent activity stream entries to return.",
					"default": 30,
					"minimum": 1,
					"maximum": 100
				}
			}
		}
	},
	"response": {
		"success": {
			"statusCode": 200,
			"contentType": "application/json",
			"body": {
				"$schema": "http://json-schema.org/draft-07/schema#",
				"type": "object",
				"required": ["userId", "heatmap", "streak", "subjects", "recentActivity"],
				"properties": {
					"userId": {
						"type": "string",
						"description": "The user ID this timeline belongs to."
					},
					"heatmap": {
						"type": "object",
						"description": "Daily activity data for the GitHub-style contribution heatmap.",
						"required": ["timeline", "totalDays", "totalActivity"],
						"properties": {
							"timeline": {
								"type": "array",
								"description": "Array of daily activity counts.",
								"items": {
									"type": "object",
									"required": ["date", "count"],
									"properties": {
										"date": {
											"type": "string",
											"format": "date",
											"description": "Date in YYYY-MM-DD format."
										},
										"count": {
											"type": "integer",
											"minimum": 0,
											"description": "Number of activities on this date."
										}
									}
								}
							},
							"totalDays": {
								"type": "integer",
								"minimum": 0,
								"description": "Total number of days in the timeline window."
							},
							"totalActivity": {
								"type": "integer",
								"minimum": 0,
								"description": "Sum of all activity counts across the timeline."
							}
						}
					},
					"streak": {
						"type": "object",
						"description": "Study streak information for the StreakCounter component.",
						"required": ["currentStreak", "bestStreak", "lastStudiedAt"],
						"properties": {
							"currentStreak": {
								"type": "integer",
								"minimum": 0,
								"description": "Current consecutive days of study."
							},
							"bestStreak": {
								"type": "integer",
								"minimum": 0,
								"description": "Highest consecutive day streak ever achieved."
							},
							"lastStudiedAt": {
								"type": "string",
								"format": "date-time",
								"description": "ISO 8601 timestamp of the most recent study activity."
							}
						}
					},
					"subjects": {
						"type": "array",
						"description": "Per-subject progress data for the ProgressRings component.",
						"items": {
							"type": "object",
							"required": ["name", "color", "progress", "attempted", "target"],
							"properties": {
								"name": {
									"type": "string",
									"description": "Subject display name (e.g., 'Mathematics')."
								},
								"color": {
									"type": "string",
									"description": "CSS color value for the ring visualization."
								},
								"progress": {
									"type": "integer",
									"minimum": 0,
									"maximum": 100,
									"description": "Completion percentage (0-100)."
								},
								"attempted": {
									"type": "integer",
									"minimum": 0,
									"description": "Number of questions/items attempted in this subject."
								},
								"target": {
									"type": "integer",
									"minimum": 0,
									"description": "Target number of questions/items for this subject."
								}
							}
						}
					},
					"accuracyTrends": {
						"type": "array",
						"description": "Per-subject accuracy over time for the AccuracyTrend component.",
						"items": {
							"type": "object",
							"required": ["subject", "color", "data"],
							"properties": {
								"subject": {
									"type": "string",
									"description": "Subject name."
								},
								"color": {
									"type": "string",
									"description": "CSS color for the chart."
								},
								"data": {
									"type": "array",
									"items": {
										"type": "object",
										"required": ["date", "accuracy"],
										"properties": {
											"date": {
												"type": "string",
												"format": "date",
												"description": "Date in YYYY-MM-DD format."
											},
											"accuracy": {
												"type": "number",
												"minimum": 0,
												"maximum": 100,
												"description": "Accuracy percentage for that date."
											}
										}
									}
								}
							}
						}
					},
					"weakTopics": {
						"type": "array",
						"description": "Topics with low accuracy for the WeakTopicHighlights component.",
						"items": {
							"type": "object",
							"required": ["name", "accuracy", "attempted", "suggestedAction"],
							"properties": {
								"name": {
									"type": "string",
									"description": "Topic name."
								},
								"accuracy": {
									"type": "integer",
									"minimum": 0,
									"maximum": 100,
									"description": "Accuracy percentage for this topic."
								},
								"attempted": {
									"type": "integer",
									"minimum": 0,
									"description": "Number of questions attempted in this topic."
								},
								"suggestedAction": {
									"type": "string",
									"description": "Recommended action to improve (e.g., 'Practice 20 more questions on algebra')."
								}
							}
						}
					},
					"cohortComparison": {
						"type": "object",
						"description": "Cohort-relative performance data for the CohortComparison component.",
						"required": ["userAccuracy", "cohortAverage", "percentile"],
						"properties": {
							"userAccuracy": {
								"type": "number",
								"minimum": 0,
								"maximum": 100,
								"description": "User's overall accuracy percentage."
							},
							"cohortAverage": {
								"type": "number",
								"minimum": 0,
								"maximum": 100,
								"description": "Average accuracy across the peer cohort."
							},
							"percentile": {
								"type": "integer",
								"minimum": 0,
								"maximum": 100,
								"description": "User's percentile rank within the cohort."
							}
						}
					},
					"recentActivity": {
						"type": "array",
						"description": "Most recent activity entries for the ActivityStream component.",
						"items": {
							"type": "object",
							"required": ["type", "title", "detail", "timestamp"],
							"properties": {
								"type": {
									"type": "string",
									"enum": ["quiz", "flashcard", "study", "achievement"],
									"description": "Category of activity."
								},
								"title": {
									"type": "string",
									"description": "Short activity title."
								},
								"detail": {
									"type": "string",
									"description": "Additional detail about the activity."
								},
								"timestamp": {
									"type": "string",
									"format": "date-time",
									"description": "ISO 8601 timestamp of the activity."
								}
							}
						}
					}
				},
				"additionalProperties": false
			}
		},
		"notFound": {
			"statusCode": 404,
			"contentType": "application/json",
			"body": {
				"$schema": "http://json-schema.org/draft-07/schema#",
				"type": "object",
				"required": ["error"],
				"properties": {
					"error": {
						"type": "string",
						"description": "Error message indicating user not found."
					}
				},
				"additionalProperties": false
			}
		},
		"error": {
			"statusCode": 500,
			"contentType": "application/json",
			"body": {
				"$schema": "http://json-schema.org/draft-07/schema#",
				"type": "object",
				"required": ["error"],
				"properties": {
					"error": {
						"type": "string",
						"description": "Error message describing the failure."
					}
				},
				"additionalProperties": false
			}
		}
	},
	"examples": {
		"response": {
			"userId": "usr_abc123",
			"heatmap": {
				"timeline": [
					{ "date": "2025-10-13", "count": 5 },
					{ "date": "2025-10-14", "count": 3 },
					{ "date": "2025-10-15", "count": 0 }
				],
				"totalDays": 180,
				"totalActivity": 487
			},
			"streak": {
				"currentStreak": 12,
				"bestStreak": 21,
				"lastStudiedAt": "2026-04-12T18:30:00.000Z"
			},
			"subjects": [
				{
					"name": "Mathematics",
					"color": "#3B82F6",
					"progress": 68,
					"attempted": 347,
					"target": 500
				},
				{
					"name": "Physics",
					"color": "#22C55E",
					"progress": 52,
					"attempted": 198,
					"target": 400
				}
			],
			"accuracyTrends": [
				{
					"subject": "Mathematics",
					"color": "#3B82F6",
					"data": [
						{ "date": "2026-04-01", "accuracy": 62.5 },
						{ "date": "2026-04-07", "accuracy": 68.3 },
						{ "date": "2026-04-13", "accuracy": 71.1 }
					]
				}
			],
			"weakTopics": [
				{
					"name": "Trigonometry",
					"accuracy": 28,
					"attempted": 15,
					"suggestedAction": "Practice 20 more questions on trigonometric identities"
				}
			],
			"cohortComparison": {
				"userAccuracy": 71.1,
				"cohortAverage": 58.4,
				"percentile": 82
			},
			"recentActivity": [
				{
					"type": "quiz",
					"title": "Mathematics Quiz",
					"detail": "Scored 85% on Algebra quiz (17/20)",
					"timestamp": "2026-04-12T18:30:00.000Z"
				},
				{
					"type": "study",
					"title": "Study Session",
					"detail": "45 minutes on Physics - Newton's Laws",
					"timestamp": "2026-04-12T16:00:00.000Z"
				}
			]
		}
	}
}
