{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "Enrichment Stats API",
	"description": "GET /api/enrichment/stats - Returns pipeline statistics, quarantine information, and the source registry. No authentication required.",
	"request": {
		"method": "GET",
		"url": "/api/enrichment/stats"
	},
	"response": {
		"success": {
			"statusCode": 200,
			"contentType": "application/json",
			"body": {
				"$schema": "http://json-schema.org/draft-07/schema#",
				"type": "object",
				"required": ["stats", "quarantineCount", "recentQuarantine", "sources", "timestamp"],
				"properties": {
					"stats": {
						"type": "object",
						"description": "Aggregate pipeline statistics.",
						"required": [
							"totalSources",
							"totalRecordsProcessed",
							"totalRecordsPersisted",
							"totalRecordsQuarantined",
							"lastRunAt",
							"averageDuration"
						],
						"properties": {
							"totalSources": {
								"type": "integer",
								"minimum": 0,
								"description": "Total number of registered enrichment sources."
							},
							"totalRecordsProcessed": {
								"type": "integer",
								"minimum": 0,
								"description": "Cumulative number of records processed across all runs."
							},
							"totalRecordsPersisted": {
								"type": "integer",
								"minimum": 0,
								"description": "Cumulative number of records successfully persisted."
							},
							"totalRecordsQuarantined": {
								"type": "integer",
								"minimum": 0,
								"description": "Cumulative number of records quarantined due to validation failure."
							},
							"lastRunAt": {
								"type": ["string", "null"],
								"format": "date-time",
								"description": "ISO 8601 timestamp of the last pipeline run. Null if never run."
							},
							"averageDuration": {
								"type": "integer",
								"minimum": 0,
								"description": "Average pipeline run duration in milliseconds."
							}
						}
					},
					"quarantineCount": {
						"type": "integer",
						"minimum": 0,
						"description": "Total number of records currently in quarantine."
					},
					"recentQuarantine": {
						"type": "array",
						"description": "Up to 10 most recent quarantine entries.",
						"items": {
							"type": "object",
							"required": ["sourceId", "reason", "timestamp"],
							"properties": {
								"sourceId": {
									"type": "string",
									"description": "ID of the source that produced the quarantined record."
								},
								"reason": {
									"type": "string",
									"description": "Reason the record was quarantined (validation failure details)."
								},
								"timestamp": {
									"type": "string",
									"format": "date-time",
									"description": "ISO 8601 timestamp when the record was quarantined."
								}
							}
						}
					},
					"sources": {
						"type": "array",
						"description": "Registry of all configured enrichment sources.",
						"items": {
							"type": "object",
							"required": ["id", "name", "type", "license", "schedule"],
							"properties": {
								"id": {
									"type": "string",
									"description": "Unique identifier for the source."
								},
								"name": {
									"type": "string",
									"description": "Human-readable source name."
								},
								"type": {
									"type": "string",
									"enum": ["api", "scrape", "manual"],
									"description": "Source type: API (structured endpoint), scrape (HTML parsing), or manual (human-curated)."
								},
								"license": {
									"type": "string",
									"description": "Data license identifier (e.g., 'CC-BY-4.0', 'Public Domain')."
								},
								"schedule": {
									"type": "string",
									"enum": ["weekly", "monthly", "quarterly"],
									"description": "Recommended refresh frequency for this source."
								}
							}
						}
					},
					"timestamp": {
						"type": "string",
						"format": "date-time",
						"description": "ISO 8601 timestamp when this stats response was generated."
					}
				},
				"additionalProperties": false
			}
		},
		"error": {
			"statusCode": 500,
			"contentType": "application/json",
			"body": {
				"$schema": "http://json-schema.org/draft-07/schema#",
				"type": "object",
				"required": ["error"],
				"properties": {
					"error": {
						"type": "string",
						"description": "Error message describing the failure."
					}
				},
				"additionalProperties": false
			}
		}
	},
	"examples": {
		"response": {
			"stats": {
				"totalSources": 3,
				"totalRecordsProcessed": 150,
				"totalRecordsPersisted": 142,
				"totalRecordsQuarantined": 8,
				"lastRunAt": "2026-04-13T09:15:00.000Z",
				"averageDuration": 3200
			},
			"quarantineCount": 8,
			"recentQuarantine": [
				{
					"sourceId": "openstax-physics",
					"reason": "Missing required field: subject",
					"timestamp": "2026-04-13T09:14:58.000Z"
				}
			],
			"sources": [
				{
					"id": "dbe-past-papers",
					"name": "DBE Past Papers",
					"type": "scrape",
					"license": "Public Domain",
					"schedule": "weekly"
				},
				{
					"id": "openstax-physics",
					"name": "OpenStax Physics",
					"type": "api",
					"license": "CC-BY-4.0",
					"schedule": "monthly"
				}
			],
			"timestamp": "2026-04-13T10:30:00.000Z"
		}
	}
}
