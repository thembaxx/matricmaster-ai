{
	"$schema": "https://opencode.ai/config.json",
	"mcp": {
		"Sentry": {
			"type": "remote",
			"url": "https://mcp.sentry.dev/mcp/org1128/javascript-nextjs",
			"oauth": {}
		},
		"github": {
			"type": "stdio",
			"command": "npx",
			"args": ["-y", "@modelcontextprotocol/server-github"],
			"env": {
				"GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
			}
		}
	}
}
