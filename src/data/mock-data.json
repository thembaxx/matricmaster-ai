			"updatedAt": "2024-01-01T00:00:00Z"
		},
		{
			"id": "q2",
			"subjectId": 1,
			"questionText": "Calculate the derivative of f(x) = 3x³ + 2x² - 5x + 1",
			"imageUrl": null,
			"gradeLevel": 12,
			"topic": "Calculus",
			"difficulty": "medium",
			"marks": 4,
			"hint": "Use the power rule: d/dx(x^n) = nx^(n-1)",
			"isActive": true,
			"createdAt": "2024-01-01T00:00:00Z",
			"updatedAt": "2024-01-01T00:00:00Z"
		},
		{
			"id": "q3",
			"subjectId": 2,
			"questionText": "What is the atomic number of Carbon?",
			"imageUrl": null,
			"gradeLevel": 10,
			"topic": "Chemistry - Atomic Structure",
			"difficulty": "easy",
			"marks": 1,
			"hint": "Look at the periodic table",
			"isActive": true,
