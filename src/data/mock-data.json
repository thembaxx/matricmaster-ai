			"updatedAt": "2024-01-01T00:00:00Z"
		}
	],
	"options": [
		{
			"id": "o1",
			"questionId": "q1",
			"optionText": "x = 2 or x = 3",
			"isCorrect": true,
			"optionLetter": "A",
			"explanation": "Factorizing: x² - 5x + 6 = (x-2)(x-3) = 0, so x = 2 or x = 3",
			"isActive": true,
			"createdAt": "2024-01-01T00:00:00Z"
		},
		{
			"id": "o2",
			"questionId": "q1",
			"optionText": "x = 1 or x = 6",
			"isCorrect": false,
			"optionLetter": "B",
			"explanation": "1 × 6 = 6, but 1 + 6 = 7, not 5",
			"isActive": true,
			"createdAt": "2024-01-01T00:00:00Z"
		},
		{
			"id": "o3",
			"questionId": "q1",
			"optionText": "x = -2 or x = -3",
			"isCorrect": false,
			"optionLetter": "C",
			"explanation": "(-2)(-3) = 6, but -2 + (-3) = -5",
			"isActive": true,
			"createdAt": "2024-01-01T00:00:00Z"
		},
		{
			"id": "o4",
			"questionId": "q1",
			"optionText": "x = 4 or x = 1",
			"isCorrect": false,
			"optionLetter": "D",
			"explanation": "4 × 1 = 4, not 6",
			"isActive": true,
			"createdAt": "2024-01-01T00:00:00Z"
		},
		{
			"id": "o5",
			"questionId": "q2",
			"optionText": "f'(x) = 9x² + 4x - 5",
			"isCorrect": true,
			"optionLetter": "A",
			"explanation": "Using power rule: d/dx(3x³) = 9x², d/dx(2x²) = 4x, d/dx(-5x) = -5, d/dx(1) = 0",
			"isActive": true,
			"createdAt": "2024-01-01T00:00:00Z"
		},
		{
			"id": "o6",
			"questionId": "q2",
			"optionText": "f'(x) = 3x² + 2x - 5",
			"isCorrect": false,
			"optionLetter": "B",
			"explanation": "Missing the coefficient multiplication from power rule",
			"isActive": true,
			"createdAt": "2024-01-01T00:00:00Z"
		},
		{
			"id": "o7",
			"questionId": "q3",
			"optionText": "6",
			"isCorrect": true,
			"optionLetter": "A",
			"explanation": "Carbon has 6 protons, hence atomic number 6",
			"isActive": true,
			"createdAt": "2024-01-01T00:00:00Z"
		},
		{
			"id": "o8",
			"questionId": "q3",
			"optionText": "12",
			"isCorrect": false,
			"optionLetter": "B",
			"explanation": "12 is the mass number, not atomic number",
			"isActive": true,
			"createdAt": "2024-01-01T00:00:00Z"
		},
		{
			"id": "o9",
			"questionId": "q4",
			"optionText": "10 m/s",
			"isCorrect": true,
			"optionLetter": "A",
			"explanation": "v = u + at = 0 + (2)(5) = 10 m/s",
			"isActive": true,
			"createdAt": "2024-01-01T00:00:00Z"
		},
		{
			"id": "o10",
			"questionId": "q4",
			"optionText": "25 m/s",
			"isCorrect": false,
			"optionLetter": "B",
			"explanation": "That's s = ut + ½at², not velocity",
			"isActive": true,
			"createdAt": "2024-01-01T00:00:00Z"
		},
		{
			"id": "o11",
			"questionId": "q5",
			"optionText": "Mitochondria",
			"isCorrect": true,
			"optionLetter": "A",
			"explanation": "Mitochondria produce ATP through cellular respiration",
			"isActive": true,
			"createdAt": "2024-01-01T00:00:00Z"
		},
		{
