			"updatedAt": "2024-01-01T00:00:00Z"
		},
		{
			"id": "q4",
			"subjectId": 2,
			"questionText": "A car accelerates from rest at 2 m/s². What is its velocity after 5 seconds?",
			"imageUrl": null,
			"gradeLevel": 11,
			"topic": "Physics - Kinematics",
			"difficulty": "medium",
			"marks": 3,
			"hint": "Use v = u + at",
